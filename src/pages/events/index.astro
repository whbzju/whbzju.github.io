---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { events, profile } from "../../data/profile";

const featuredEventSelections = [
  {
    title: "AI应用 WeShop 卷到海外，智能时代的新外贸故事",
    reasonEn:
      "Shows WeShop as a global AI SaaS product, beyond a China-only AIGC experiment.",
    reasonZh: "说明 WeShop 已经不是一个国内 AIGC 尝试，而是面向全球用户的 AI SaaS 产品。",
  },
  {
    title: "WeShop唯象总经理吴海波：AI创业已非“套壳应用”时代",
    reasonEn:
      "The clearest public version of the current thesis: AI products need scenario depth, workflow ownership, and commercial quality.",
    reasonZh: "最能概括我现在的判断：AI 产品不是套模型，而是要深入场景、工作流和商业质量。",
    links: [
      {
        labelEn: "36Kr talk",
        labelZh: "36氪演讲",
        href: "https://m.36kr.com/p/3262118027476743",
      },
      {
        labelEn: "English coverage",
        labelZh: "英文报道",
        href: "https://eu.36kr.com/en/p/3262118027476743",
      },
    ],
  },
  {
    title: "组织的野望：AI 公司全员远程办公可行吗？",
    reasonEn:
      "A useful window into the operating system behind the work: remote collaboration, autonomy, and AI-native team rhythm.",
    reasonZh: "补充产品背后的组织方式：远程协作、自主性，以及 AI 原生团队的工作节奏。",
  },
  {
    title: "2024 腾讯数字生态大会：WeShop 总经理吴海波展望 AI 商拍未来",
    reasonEn:
      "A representative conference appearance on AI commercial photography, multimodal models, and vertical AI applications.",
    reasonZh: "代表性的大会分享，集中讨论 AI 商拍、多模态模型和垂直 AI 应用。",
  },
  {
    title: "Sora 爆火将如何改变广告行业？",
    reasonEn:
      "Captures the broader industry judgment around video generation, advertising, and creative workflows.",
    reasonZh: "体现我对视频生成、广告行业和商业创意工作流变化的判断。",
  },
  {
    title: "AI 落地进行时，让创新真正触手可及",
    reasonEn:
      "Connects model progress with the harder last mile of real industry adoption.",
    reasonZh: "连接模型能力和产业落地，回答 AI 怎么真正进入业务现场。",
  },
  {
    title: "极新对话 WeShop 总经理吴海波｜投身 AI，大胆创新",
    reasonEn:
      "A longer-form interview on product taste, AI application judgment, and commercializing WeShop.",
    reasonZh: "比较完整的一次长访谈，谈 AI 产品感、应用判断和 WeShop 商业化。",
  },
  {
    title: "WeShop 团队从大模型研发走向 AI 商拍产品化",
    reasonEn:
      "Marks the earlier arc from model R&D into a concrete commercial product.",
    reasonZh: "作为早期脉络节点，说明团队如何从大模型研发走向 AI 商拍产品化。",
  },
];

const eventsByTitle = new Map(events.map((event) => [event.title, event]));

const featuredEvents = featuredEventSelections
  .map((selection) => {
    const event = eventsByTitle.get(selection.title);

    if (!event) return null;

    return {
      ...event,
      reasonEn: selection.reasonEn,
      reasonZh: selection.reasonZh,
      links:
        selection.links ?? [
          {
            labelEn: "Source",
            labelZh: "来源",
            href: event.href,
          },
        ],
    };
  })
  .filter(Boolean);

const eventGroups = featuredEvents.reduce((groups, event) => {
  const year = /^\d{4}-\d{4}$/.test(event.date)
    ? event.date
    : event.date.match(/^\d{4}/)?.[0] ?? event.date;
  const current = groups[groups.length - 1];

  if (!current || current.year !== year) {
    groups.push({ year, items: [event] });
  } else {
    current.items.push(event);
  }

  return groups;
}, []);
---

<BaseLayout title={`Events · ${profile.name}`}>
  <section class="page-hero container">
    <div>
      <p class="eyebrow">
        <span data-lang-content="en">Events</span>
        <span data-lang-content="zh">活动</span>
      </p>
      <h1>
        <span data-lang-content="en">Talks, interviews, and public appearances.</span>
        <span data-lang-content="zh">演讲、访谈和公开活动。</span>
      </h1>
    </div>
    <p class="page-lead" data-lang-content="en">A deliberately selective record of public moments that explain the arc: WeShop's product thinking, commercialization, AI-native organization, and earlier productization work.</p>
    <p class="page-lead" data-lang-content="zh">这里只保留能说明脉络的公开记录：WeShop 的产品判断、商业化、AI 原生组织，以及从技术实践走向产品化的几个节点。</p>
  </section>

  <section class="section">
    <div class="container">
      <div class="events-timeline">
        {eventGroups.map((group) => (
          <section class="event-year">
            <h2>{group.year}</h2>
            <ol class="event-list">
              {group.items.map((item) => (
                <li class="event-item">
                  <div class="event-meta">
                    <time datetime={item.date}>{item.date}</time>
                    <span data-lang-content="en">{item.kind}</span>
                    <span data-lang-content="zh">{item.kindZh}</span>
                    <span data-lang-content="en">{item.source}</span>
                    <span data-lang-content="zh">{item.sourceZh}</span>
                  </div>
                  <h3>
                    <span data-lang-content="en">{item.titleEn}</span>
                    <span data-lang-content="zh">{item.titleZh}</span>
                  </h3>
                  <p data-lang-content="en">{item.noteEn}</p>
                  <p data-lang-content="zh">{item.note}</p>
                  <p class="event-reason" data-lang-content="en">{item.reasonEn}</p>
                  <p class="event-reason" data-lang-content="zh">{item.reasonZh}</p>
                  <div class="event-links" aria-label="Event sources">
                    {item.links.map((link) => (
                      <a class="event-link" href={link.href} target="_blank" rel="noopener noreferrer">
                        <span data-lang-content="en">{link.labelEn}</span>
                        <span data-lang-content="zh">{link.labelZh}</span>
                      </a>
                    ))}
                  </div>
                </li>
              ))}
            </ol>
          </section>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
