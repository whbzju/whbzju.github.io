---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { principles, profile, works } from "../../data/profile";
---

<BaseLayout title={`Thesis · ${profile.name}`}>
  <section class="page-hero container">
    <div>
      <p class="eyebrow">Thesis</p>
      <h1>What I am trying to prove.</h1>
    </div>
    <p class="page-lead">The commercial product, the open-source product, and the blog are not separate biographies. They are three views of the same AI application thesis.</p>
  </section>

  <section class="section">
    <div class="container">
      <div class="split-panel">
        <div class="principle-grid">
          {principles.map((item) => (
            <article class="principle-card">
              <h3>{item.title}</h3>
              <p>{item.text}</p>
            </article>
          ))}
        </div>
        <aside class="aside-panel">
          <p class="eyebrow">How it maps to work</p>
          {works.map((work) => (
            <div class="signal">
              <span>{work.title}</span>
              <strong>{work.thesis}</strong>
            </div>
          ))}
        </aside>
      </div>
    </div>
  </section>
</BaseLayout>
