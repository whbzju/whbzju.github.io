---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { profile, writingHighlights } from "../../data/profile";
import blogPosts from "../../data/blog-posts.json";

const highlightGroups = [...new Set(writingHighlights.map((item) => item.group))].map((group) => {
  const items = writingHighlights.filter((item) => item.group === group);
  return {
    group,
    groupZh: items[0].groupZh,
    items,
  };
});
---

<BaseLayout title={`Blog · ${profile.name}`}>
  <section class="page-hero container">
    <div>
      <p class="eyebrow">
        <span data-lang-content="en">Blog</span>
        <span data-lang-content="zh">文章</span>
      </p>
      <h1>
        <span data-lang-content="en">Writing and selected answers.</span>
        <span data-lang-content="zh">文章与代表回答。</span>
      </h1>
    </div>
    <p class="page-lead" data-lang-content="en">A curated reading path across Memex, WeShop, AI applications, generative models, search, recommendation, and earlier machine-learning work.</p>
    <p class="page-lead" data-lang-content="zh">按主题整理我在知乎和专栏里较有代表性的文章与回答，覆盖 Memex、WeShop、AI 应用、生成模型、搜索推荐和早期机器学习实践。</p>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">
            <span data-lang-content="en">Selected</span>
            <span data-lang-content="zh">精选</span>
          </p>
          <h2>
            <span data-lang-content="en">Featured essays.</span>
            <span data-lang-content="zh">精选长文。</span>
          </h2>
        </div>
        <p class="section-lead" data-lang-content="en">These essays are available as full pages here. Chinese keeps the original Zhihu text; English is translated for international readers.</p>
        <p class="section-lead" data-lang-content="zh">这几篇已迁移到本站。中文保留知乎原文，英文提供译文。</p>
      </div>
      <div class="post-list">
        {blogPosts.map((post) => (
          <a class="post-list-item" href={`/blog/${post.slug}/`}>
            <span class="item-source">
              <span data-lang-content="en">{post.date} · {post.source}</span>
              <span data-lang-content="zh">{post.date} · 知乎原文</span>
            </span>
            <h3>
              <span data-lang-content="en">{post.titleEn}</span>
              <span data-lang-content="zh">{post.titleZh}</span>
            </h3>
            <p data-lang-content="en">{post.excerptEn}</p>
            <p data-lang-content="zh">{post.excerptZh}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-header">
        <div>
          <p class="eyebrow">
            <span data-lang-content="en">Selected notes</span>
            <span data-lang-content="zh">精选笔记</span>
          </p>
          <h2>
            <span data-lang-content="en">Product, technical, and product-thinking notes.</span>
            <span data-lang-content="zh">产品、技术和产品判断。</span>
          </h2>
        </div>
        <p class="section-lead" data-lang-content="en">A smaller set of representative public notes. English readers get translated titles and context here; Chinese originals remain as sources.</p>
        <p class="section-lead" data-lang-content="zh">这一组只保留更能代表产品实践、技术理解和产品理念的内容。中文原文作为来源保留。</p>
      </div>

      {highlightGroups.map((group) => (
        <section class="highlight-group">
          <h3>
            <span data-lang-content="en">{group.group}</span>
            <span data-lang-content="zh">{group.groupZh}</span>
          </h3>
          <ul class="writing-note-list">
            {group.items.map((item) => (
              <li class="writing-note">
                <div class="event-meta">
                  <span data-lang-content="en">{item.type}</span>
                  <span data-lang-content="zh">{item.typeZh}</span>
                </div>
                <h4>
                  <span data-lang-content="en">{item.titleEn}</span>
                  <span data-lang-content="zh">{item.title}</span>
                </h4>
                <p data-lang-content="en">{item.noteEn}</p>
                <p data-lang-content="zh">{item.note}</p>
                <a class="event-link" href={item.href} target="_blank" rel="noopener noreferrer">
                  <span data-lang-content="en">Source</span>
                  <span data-lang-content="zh">中文原文</span>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>
  </section>
</BaseLayout>
